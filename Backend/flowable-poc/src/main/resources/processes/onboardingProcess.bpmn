<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:flowable="http://flowable.org/bpmn" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:omgdc="http://www.omg.org/spec/DD/20100524/DC" xmlns:omgdi="http://www.omg.org/spec/DD/20100524/DI" xmlns:design="http://flowable.org/design" typeLanguage="http://www.w3.org/2001/XMLSchema" expressionLanguage="http://www.w3.org/1999/XPath" targetNamespace="http://flowable.org/test" exporter="Flowable Design" exporterVersion="2025.1.03" design:palette="flowable-work-process-palette">
  <process id="onboardingProcess" name="Customer Onboarding Process" isExecutable="true" flowable:candidateStarterGroups="flowableUser">
    <extensionElements>
      <design:stencilid><![CDATA[BPMNDiagram]]></design:stencilid>
      <design:creationdate><![CDATA[2026-03-15T22:58:28.542Z]]></design:creationdate>
      <design:modificationdate><![CDATA[2026-03-17T11:32:08.648Z]]></design:modificationdate>
    </extensionElements>
    <userTask id="FormTask_1" flowable:assignee="${initiator}" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:element-name>Collect Basic Info
</flowable:element-name>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <serviceTask id="BusinessRuleTask_3" flowable:type="dmn">
      <extensionElements>
        <flowable:element-name>Evaluate Onboarding Decision
</flowable:element-name>
        <flowable:field name="decisionTableReferenceKey">
          <flowable:string><![CDATA[onboardingDecision]]></flowable:string>
        </flowable:field>
        <flowable:field name="decisionTaskThrowErrorOnNoHits">
          <flowable:string><![CDATA[true]]></flowable:string>
        </flowable:field>
        <flowable:field name="fallbackToDefaultTenant">
          <flowable:string><![CDATA[true]]></flowable:string>
        </flowable:field>
        <flowable:field name="sameDeployment">
          <flowable:string><![CDATA[true]]></flowable:string>
        </flowable:field>
        <flowable:decisionReferenceType><![CDATA[decisionTable]]></flowable:decisionReferenceType>
        <design:stencilid><![CDATA[DmnTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </serviceTask>
    <userTask id="FormTask_9" name="Collect Non-Citizen Details" flowable:assignee="${initiator}" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <userTask id="FormTask_7" flowable:assignee="${initiator}" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:element-name>Collect Citizen Details
</flowable:element-name>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <userTask id="FormTask_33" name="Citizen Verification" flowable:assignee="${initiator}" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <userTask id="FormTask_11" flowable:assignee="${initiator}" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:element-name>Review Application
</flowable:element-name>
        <flowable:task-candidates-type><![CDATA[all]]></flowable:task-candidates-type>
        <design:stencilid><![CDATA[FormTask]]></design:stencilid>
        <design:stencilsuperid><![CDATA[Task]]></design:stencilsuperid>
      </extensionElements>
    </userTask>
    <exclusiveGateway id="Exclusive_Databased_Gateway_5" name="Citizen Check">
      <extensionElements>
        <design:stencilid><![CDATA[Exclusive_Databased_Gateway]]></design:stencilid>
        <design:display_ref_in_diagram><![CDATA[true]]></design:display_ref_in_diagram>
      </extensionElements>
    </exclusiveGateway>
    <startEvent id="startnoneevent1" name="Start Onboarding" flowable:initiator="initiator" flowable:formFieldValidation="false">
      <extensionElements>
        <flowable:work-form-field-validation><![CDATA[false]]></flowable:work-form-field-validation>
        <design:stencilid><![CDATA[StartNoneEvent]]></design:stencilid>
        <design:display_ref_in_diagram><![CDATA[true]]></design:display_ref_in_diagram>
      </extensionElements>
    </startEvent>
    <endEvent id="EndNoneEvent_14" name="Onboarding Complete">
      <extensionElements>
        <design:stencilid><![CDATA[EndNoneEvent]]></design:stencilid>
        <design:display_ref_in_diagram><![CDATA[true]]></design:display_ref_in_diagram>
      </extensionElements>
    </endEvent>
    <endEvent id="EndNoneEvent_33" name="Application Rejected">
      <extensionElements>
        <design:stencilid><![CDATA[EndNoneEvent]]></design:stencilid>
        <design:display_ref_in_diagram><![CDATA[true]]></design:display_ref_in_diagram>
      </extensionElements>
    </endEvent>
    <sequenceFlow id="SequenceFlow_4" sourceRef="FormTask_1" targetRef="BusinessRuleTask_3">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_6" sourceRef="BusinessRuleTask_3" targetRef="Exclusive_Databased_Gateway_5">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_40" sourceRef="FormTask_9" targetRef="FormTask_11">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_38" sourceRef="FormTask_7" targetRef="FormTask_11">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_39" sourceRef="FormTask_33" targetRef="FormTask_11">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_15" sourceRef="FormTask_11" targetRef="EndNoneEvent_14">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_2" sourceRef="startnoneevent1" targetRef="FormTask_1">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_34" sourceRef="Exclusive_Databased_Gateway_5" targetRef="FormTask_33">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${decisionResult == "citizenVerificationflow"}]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_35" sourceRef="Exclusive_Databased_Gateway_5" targetRef="FormTask_7">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${decisionResult == "citizenFlow"}]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_36" sourceRef="Exclusive_Databased_Gateway_5" targetRef="EndNoneEvent_33">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${decisionResult == "rejectFlow"}]]></conditionExpression>
    </sequenceFlow>
    <sequenceFlow id="SequenceFlow_37" sourceRef="Exclusive_Databased_Gateway_5" targetRef="FormTask_9">
      <extensionElements>
        <design:stencilid><![CDATA[SequenceFlow]]></design:stencilid>
      </extensionElements>
      <conditionExpression xsi:type="tFormalExpression"><![CDATA[${decisionResult == "passportFlow"}]]></conditionExpression>
    </sequenceFlow>
  </process>
